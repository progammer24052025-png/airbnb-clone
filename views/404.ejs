<%- include('partials/head') %>
    </head>

    <body class="bg-[#f7f7f7] min-h-screen flex flex-col">
        <%- include('partials/Nav') %>

            <main class="flex-1 flex items-center justify-center px-4 py-16">
                <div class="w-full max-w-md sm:max-w-xl bg-white rounded-3xl border border-gray-200 shadow-xl p-8 sm:p-10 text-center">

                    <!-- 404 Number -->
                    <h1 class="text-5xl font-bold text-[#FF385C] mb-4">
                        404
                    </h1>

                    <!-- Error Title -->
                    <h2 class="text-2xl sm:text-3xl font-semibold text-gray-900 mb-4">
                        Page Not Found
                    </h2>

                    <!-- Description -->
                    <p class="text-gray-500 text-base sm:text-lg mb-8">
                        The page you are looking for doesn't exist or may have been moved.
                    </p>

                    <!-- Button -->
                    <a href="/"
                        class="bg-[#FF385C] text-white px-5 py-2.5 rounded-full font-medium hover:bg-[#e03150] transition">
                        Back to Home
                    </a>

                </div>
            </main>

    </body>

    </html>